Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"GreensFunction", "[", 
     RowBox[{"A_", ",", "B_", ",", "atom_"}], "]"}], "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Im", "[", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Conjugate", "@", 
           RowBox[{
            RowBox[{"Wavefunction", "[", 
             RowBox[{"A", ",", "B"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"n", ",", "atom"}], "]"}], "]"}]}], "*", 
          RowBox[{
           RowBox[{
            RowBox[{"Wavefunction", "[", 
             RowBox[{"A", ",", "B"}], "]"}], "[", 
            RowBox[{"[", 
             RowBox[{"n", ",", "atom"}], "]"}], "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"\[Omega]", "-", 
             RowBox[{"\[ImaginaryI]", "*", "0.1"}], "-", 
             RowBox[{
              RowBox[{"Energy", "[", 
               RowBox[{"A", ",", "B"}], "]"}], "[", 
              RowBox[{"[", "n", "]"}], "]"}]}], ")"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"n", ",", "1", ",", "2"}], "}"}]}], "]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Omega]", ",", 
        RowBox[{"-", "6"}], ",", "6", ",", "0.1"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"MaxGreensFunction", "[", 
   RowBox[{"A_", ",", "B_", ",", "atom_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "mat", "}"}], ",", 
    RowBox[{
     RowBox[{"mat", "=", 
      RowBox[{"GreensFunction", "[", 
       RowBox[{"A", ",", "B", ",", "atom"}], "]"}]}], ";", 
     RowBox[{"Position", "[", 
      RowBox[{"mat", ",", 
       RowBox[{"Max", "[", 
        RowBox[{"Abs", "@", "mat"}], "]"}]}], "]"}]}]}], "]"}]}]}], "Input",
